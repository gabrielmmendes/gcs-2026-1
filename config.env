# =============================================================================
# config.env — Arquivo de Configuração de Ambiente
# Projeto: Conversor PDF para PNG
# Versão:  1.0.0
#
# USO:
#   - Desenvolvimento : copie este arquivo para .env e ajuste os valores
#   - Produção        : defina as variáveis diretamente no ambiente do servidor
#   - NUNCA versione o arquivo .env com valores reais de segredos
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTIFICAÇÃO DO PROJETO
# -----------------------------------------------------------------------------
PROJECT_NAME="Conversor PDF para PNG"
PROJECT_VERSION="1.0.0"
PROJECT_ENV="development"          # development | staging | production

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DO CONVERSOR
# -----------------------------------------------------------------------------
CONVERTER_DEFAULT_SCALE=2.0        # Escala padrão de renderização (1.0 – 3.0)
CONVERTER_MIN_SCALE=1.0            # Escala mínima permitida
CONVERTER_MAX_SCALE=3.0            # Escala máxima permitida
CONVERTER_OUTPUT_FORMAT="image/png" # Formato de saída das imagens
CONVERTER_ZIP_COMPRESSION=6        # Nível de compressão ZIP (0 = sem, 9 = máximo)

# -----------------------------------------------------------------------------
# DEPENDÊNCIAS EXTERNAS (CDN)
# -----------------------------------------------------------------------------
PDFJS_VERSION="3.4.120"
PDFJS_CDN="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${PDFJS_VERSION}/pdf.min.js"

JSZIP_VERSION="3.10.1"
JSZIP_CDN="https://cdnjs.cloudflare.com/ajax/libs/jszip/${JSZIP_VERSION}/jszip.min.js"

FILESAVER_VERSION="2.0.5"
FILESAVER_CDN="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/${FILESAVER_VERSION}/FileSaver.min.js"

# -----------------------------------------------------------------------------
# FERRAMENTAS DE DESENVOLVIMENTO
# -----------------------------------------------------------------------------
PYTHON_MIN_VERSION="3.9"
PYTEST_MIN_VERSION="7.4.0"
NODE_MIN_VERSION="18.0.0"          # Necessário apenas se scripts Node forem adicionados

# -----------------------------------------------------------------------------
# INTERFACE / UI
# -----------------------------------------------------------------------------
UI_THEME_PRIMARY="#3498db"
UI_THEME_SECONDARY="#27ae60"
UI_THEME_ACCENT="#9b59b6"
UI_GRID_MIN_COL_WIDTH=300          # Largura mínima das colunas do grid (px)

# -----------------------------------------------------------------------------
# BUILD & DEPLOY
# -----------------------------------------------------------------------------
BUILD_OUTPUT_DIR="dist"            # Diretório de saída do build
BUILD_MINIFY=false                 # Minificar HTML/CSS/JS no build
DEPLOY_TARGET="static"             # static | s3 | github-pages | netlify
